# IRC Server Configuration
IRC_HOST=irc.pureirc.com
IRC_PORT=6667
IRC_SSL_PORT=6697
IRC_USE_SSL=false
IRC_NICK=PureBot
IRC_USERNAME=purebot
IRC_REALNAME=Pure IRC Bot

# WEBIRC - pass real client IPs to IRC server
# Requires a matching WEBIRC/CGI:IRC block in the IRCd config
# Leave empty to disable (all users will show the server IP)
WEBIRC_PASSWORD=

# Server Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# Database
DB_PATH=./db/users.db

# CORS
CORS_ORIGIN=http://localhost:3000

# Cache
CACHE_TTL_SECONDS=45

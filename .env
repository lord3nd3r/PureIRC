# Server Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# Database
DB_PATH=./db/users.db

# CORS
CORS_ORIGIN=http://localhost:3000

# Cache
CACHE_TTL_SECONDS=45

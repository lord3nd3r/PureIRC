# IRC Server Configuration
# Leave commented to use config.json values instead
# Uncomment only if you need to override config.json locally
# IRC_HOST=irc.rizon.net
# IRC_PORT=6667
# IRC_SSL_PORT=6697
# IRC_USE_SSL=false
# IRC_NICK=PureBot
